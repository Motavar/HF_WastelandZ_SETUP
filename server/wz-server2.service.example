# WastelandZ Game Server 2 — systemd service (Linux, multi-server "Part 3")
# 1. Copy to /etc/systemd/system/wz-server2.service   (drop the .example)
# 2. Change "youruser" below to your Linux username
# 3. sudo systemctl daemon-reload
# 4. sudo systemctl enable --now wz-server2
# Pairs with server2.json.example (ports 2002/17778, its own profile folder).
[Unit]
Description=WastelandZ Game Server 2
After=network.target

[Service]
WorkingDirectory=/opt/reforger/server
ExecStart=/opt/reforger/server/ArmaReforgerServer -config /opt/reforger/configs/server2.json -profile /opt/reforger/profiles/server2 -addonDownloadDir /opt/reforger/workshop -maxFPS 60
Restart=on-failure
User=youruser
# Big box running 2+ servers? Uncomment to give this server its own cores
# and a RAM safety cap. Core numbers differ per CPU — check with: lscpu -e
# (full walkthrough: the guide's "Big box" section in Part 3)
#CPUAffinity=8-15 24-31
#MemoryMax=32G

[Install]
WantedBy=multi-user.target
