# ============================================================
# VEHICLE TRUNK — CIVILIAN
# Applied to vehicles spawned in civilian sections of
# HFWastelandZ_vehicle_spawn.conf (Cars, Vans, Civilian Jeeps,
# Civilian Utility). Mirrors the civilian town pool weapons so
# "a vehicle in a civilian town" trunk-loots something consistent
# with "a crate in that same town". Duplicate of civilian GUARANTEED
# weapons as a starting point — tune independently as desired.
# No BONUS section — trunk loot is basic weapons only per design
# doc Decision 10. 90% of town-spawned vehicles roll this pool
# (VEHICLE_TRUNK_LOOT_CHANCE, server-configurable).
# ============================================================
[POOL vehicle_civilian_trunk]
GUARANTEED
  {9C948630078D154D}Prefabs/Weapons/Rifles/VZ58/Rifle_VZ58P.et                    weight:30  mags:2
  {BFEA719491610A45}Prefabs/Weapons/Rifles/AKS74U/Rifle_AKS74U.et                weight:20  mags:2
  {C0F7DD85A86B2900}Prefabs/Weapons/Handguns/PM/Handgun_PM.et                     weight:15  mags:3
  {1353C6EAD1DCFE43}Prefabs/Weapons/Handguns/M9/Handgun_M9.et                     weight:15  mags:3
  {A81F501D3EF6F38E}Prefabs/Items/Medicine/FieldDressing_01/FieldDressing_US_01.et weight:10
  {C3F1FA1E2EC2B345}Prefabs/Items/Medicine/FieldDressing_01/FieldDressing_USSR_01.et weight:10

# ============================================================
# VEHICLE TRUNK — MILITARY
# Applied to vehicles in military sections of the spawn catalog
# (Military Jeeps *, HMMWV, Trucks *, Specialized Trucks *,
# Ambulances, Military Utility). Mirrors the military town pool
# weapons. Duplicate of military GUARANTEED weapons.
# ============================================================
[POOL vehicle_military_trunk]
GUARANTEED
  {FA5C25BF66A53DCF}Prefabs/Weapons/Rifles/AK74/Rifle_AK74.et                     weight:20  mags:2
  {3E413771E1834D2F}Prefabs/Weapons/Rifles/M16/Rifle_M16A2.et                     weight:20  mags:2
  {9C948630078D154D}Prefabs/Weapons/Rifles/VZ58/Rifle_VZ58P.et                    weight:15  mags:2
  {BFEA719491610A45}Prefabs/Weapons/Rifles/AKS74U/Rifle_AKS74U.et                weight:15  mags:2
  {C0F7DD85A86B2900}Prefabs/Weapons/Handguns/PM/Handgun_PM.et                     weight:15  mags:3
  {1353C6EAD1DCFE43}Prefabs/Weapons/Handguns/M9/Handgun_M9.et                     weight:15  mags:3

# ============================================================
# MISSION REWARD POOLS (Phase 6 — Mission System)
# Used by mission reward crates. Pool name is referenced from
# the mission template JSON via rewards[].loot_set, e.g.:
#   "rewards": [
#     { "type": "CRATE", "loot_set": "MEDIUM_WEAPON_CRATE", "count": 2 }
#   ]
# Pool name lookup is CASE-SENSITIVE — match the JSON exactly.
# Phase 1 keeps these to weapons + bundled mags only. Add armor /
# medical / optics in Phase 2 once mission tiers are tuned.
# ============================================================

# EASY tier — pistols + AKS-74U short carbine. Light loadout.
[POOL EASY_CACHE]
GUARANTEED
  {C0F7DD85A86B2900}Prefabs/Weapons/Handguns/PM/Handgun_PM.et                     weight:30  mags:3
  {1353C6EAD1DCFE43}Prefabs/Weapons/Handguns/M9/Handgun_M9.et                     weight:30  mags:3
  {BFEA719491610A45}Prefabs/Weapons/Rifles/AKS74U/Rifle_AKS74U.et                 weight:40  mags:2

# MEDIUM tier — standard service rifles. The bread-and-butter.
[POOL MEDIUM_WEAPON_CRATE]
GUARANTEED
  {FA5C25BF66A53DCF}Prefabs/Weapons/Rifles/AK74/Rifle_AK74.et                     weight:35  mags:3
  {3E413771E1834D2F}Prefabs/Weapons/Rifles/M16/Rifle_M16A2.et                     weight:35  mags:3
  {9C948630078D154D}Prefabs/Weapons/Rifles/VZ58/Rifle_VZ58P.et                    weight:30  mags:3

# HIGH tier — same rifles, more mags + grenades. Stronger pool
# tier-distinct content (LMGs, marksman rifles) lands when those
# prefabs are catalogued in Phase 2.
[POOL HIGH_WEAPON_CRATE]
GUARANTEED
  {FA5C25BF66A53DCF}Prefabs/Weapons/Rifles/AK74/Rifle_AK74.et                     weight:30  mags:4
  {3E413771E1834D2F}Prefabs/Weapons/Rifles/M16/Rifle_M16A2.et                     weight:30  mags:4
  {9C948630078D154D}Prefabs/Weapons/Rifles/VZ58/Rifle_VZ58P.et                    weight:25  mags:4
  {E8F00BF730225B00}Prefabs/Weapons/Grenades/Grenade_M67.et                       weight:8
  {645C73791ECA1698}Prefabs/Weapons/Grenades/Grenade_RGD5.et                      weight:7

