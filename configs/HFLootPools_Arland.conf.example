# ============================================================
# HFWastelandZ — Loot Pool Definitions (Arland)
# File: HFLootPools_<MapName>.conf  (this example is for Arland)
# Location: $profile: directory
#
# WHAT THIS IS
# Loot pools define what items can spawn in town crates.
# Each pool is named to match a town type (civilian, military,
# industrial, special). When a town spawns its loot crates,
# each crate draws from the pool matching the town's type.
#
# HOW LOOT ROLLS WORK
# Each crate gets exactly one roll from GUARANTEED (always
# spawns 1 item), then a separate dice roll against the BONUS
# section. The BONUS chance is multiplied by the town's tier
# bonus_chance_mult (see HFTownTiers.conf).
#
# Example: military pool, large tier town (2.0x multiplier):
#   - Guaranteed: always 1 weapon from the GUARANTEED list
#   - Bonus: 15% base × 2.0 = 30% chance of a bonus item
#   - If weapon rolled, bundled magazines (mags:N) spawn too
#
# WEIGHT SYSTEM
# Within each section, items have a weight:N value. Higher
# weight = more likely to be picked. Weights are relative:
#   weight:30 + weight:30 + weight:20 + weight:20 = 100 total
#   First item: 30% chance, last item: 20% chance
#
# MAGAZINES
# Items with mags:N are weapons. When rolled, N magazines of
# the weapon's compatible type are automatically spawned into
# the same crate. The magazine prefab is auto-detected from
# the weapon's BaseMuzzleComponent — no need to specify it.
#
# ADDING ITEMS
# 1. Find the item's prefab GUID+path (use the store catalog
#    or Workbench resource browser)
# 2. Add a line under the appropriate pool and section
# 3. Format: {GUID}Prefabs/Path/Item.et  weight:N  [mags:N]
# 4. The server validates every prefab at boot — invalid paths
#    are skipped with a warning log
#
# WORLD POOL
# The "world" pool is used by the World Loot Scanner
# for loose items inside buildings. It should contain survival
# items only — no weapons. World loot is casual exploration
# flavor, not a combat source.
#
# ============================================================

# ============================================================
# MILITARY — bases, airfields, depots
# High-value weapons, combat gear. The premier loot pool.
# ============================================================
[POOL military]
GUARANTEED
  {FA5C25BF66A53DCF}Prefabs/Weapons/Rifles/AK74/Rifle_AK74.et                     weight:20  mags:2
  {3E413771E1834D2F}Prefabs/Weapons/Rifles/M16/Rifle_M16A2.et                     weight:20  mags:2
  {9C948630078D154D}Prefabs/Weapons/Rifles/VZ58/Rifle_VZ58P.et                    weight:15  mags:2
  {BFEA719491610A45}Prefabs/Weapons/Rifles/AKS74U/Rifle_AKS74U.et                weight:15  mags:2
  {C0F7DD85A86B2900}Prefabs/Weapons/Handguns/PM/Handgun_PM.et                     weight:15  mags:3
  {1353C6EAD1DCFE43}Prefabs/Weapons/Handguns/M9/Handgun_M9.et                     weight:15  mags:3
BONUS chance:15
  {06B68C58B72EAAC6}Prefabs/Items/Equipment/Backpacks/Backpack_ALICE_Medium.et    weight:20
  {FE5C49069C2499D9}Prefabs/Characters/HeadGear/Helmet_PASGT_01/Helmet_PASGT_01_cover.et weight:20
  {A7E6D7ECD5F684D7}Prefabs/Characters/HeadGear/Helmet_SSh68_01/Helmet_SSh68_01.et weight:20
  {0D9A5DCF89AE7AA9}Prefabs/Items/Medicine/MorphineInjection_01/MorphineInjection_01.et weight:15
  {2835A0EA3B79E63E}Prefabs/Characters/Vests/Vest_ALICE/Variants/Vest_ALICE_rifleman.et weight:15
  {E8F00BF730225B00}Prefabs/Weapons/Grenades/Grenade_M67.et                       weight:10

# ============================================================
# CIVILIAN — towns, villages, residential areas
# Basic rifles + pistols + minimal medical. Enough to get geared.
# Premium gear (optics, marksman rifles, LMGs, launchers) = missions + store.
# ============================================================
