# ============================================================
# HFWastelandZ General Store Catalog Configuration
# ============================================================
#
# OVERVIEW:
#   This file defines what items are available at general stores
#   (medical, survival, tools, grenades, explosives, ammo, mags).
#   Server admins can create multiple named catalogs with different
#   items and prices, then assign each store on the map to a catalog
#   via HFSpawnPoints_*.conf.
#
# LOCATION:
#   Place this file at: $profile:HFWastelandZ_general_catalog.conf
#
# FORMAT (same as HFWastelandZ_store_catalog.conf):
#   [CATALOG catalog_name]
#   SectionName
#     DisplayName  {GUID}Prefabs/Path/Item.et  PRICE
#
# All entries below have REAL per-prefab resource GUIDs extracted
# directly from data/resourceDatabase.rdb on 2026-04-21.
# ============================================================
#
# PRICING NOTES (suggested starting values — admin-tunable):
#   Medical (dressing, gauze):     30 - 100
#   Medical (tourniquet, morphine):100 - 250
#   Medical kits:                  500
#   Navigation (compass, map):     50 - 300
#   Binoculars:                    350 - 400
#   Radios:                        450 - 800
#   Grenades (frag):               300
#   Smoke/Flares:                  80 - 150
#   Explosives (demo, mines):      1,000 - 2,500
#   Loose ammo (rounds):           3 - 45
#   Rifle magazines:               200 - 375
#   LMG belts/boxes:               500 - 1,500
#
# Overlap with gun store:
#   - Grenades, smoke, flares, explosives, ammo, and magazines
#     are intentionally duplicated for admin convenience. Comment
#     out any section with # if exclusivity is desired.
# ============================================================

[CATALOG default]

